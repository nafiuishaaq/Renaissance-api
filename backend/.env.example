# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=renaissance_api

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Application Configuration
PORT=3000
NODE_ENV=development
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=60
CACHE_MAX=100
CACHE_STORE=memory

# Stellar/Soroban Configuration
STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_CONTRACT_ID=CC...
SOROBAN_ADMIN_SECRET=SA...
SOROBAN_SETTLEMENT_CONTRACT_ID=
SOROBAN_SPIN_REWARDS_CONTRACT_ID=
SOROBAN_NFT_CONTRACT_ID=
SOROBAN_NFT_TARGET_CONTRACT_ID=
SOROBAN_SETTLEMENT_FUNCTION=
SOROBAN_REWARD_FUNCTION=
SOROBAN_NFT_FUNCTION=
SOROBAN_TX_TIMEOUT_SECONDS=60
SOROBAN_TX_POLL_INTERVAL_MS=1500
SOROBAN_TX_POLL_ATTEMPTS=20

# RapidAPI Football Configuration
RAPIDAPI_FOOTBALL_KEY=your-rapidapi-football-key-here
RAPIDAPI_FOOTBALL_HOST=v3.football.api-sports.io

# Notifications (email + push)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@renaissance.app
WEB_PUSH_SUBJECT=mailto:support@renaissance.app
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
